# ============================================================
# Render / VPS production — copy values into Render Environment
# or /home/deploy/matcha_shopbeta/.env on VPS
# ============================================================

# ສຸ່ມດ້ວຍ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_KEY

DEBUG=0
# Render: matcha-shopbeta.onrender.com (RENDER_EXTERNAL_HOSTNAME auto-added in settings)
ALLOWED_HOSTS=matcha-shopbeta.onrender.com

# Supabase / PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# Shop branding
SHOP_NAME=The 196 Haus
SHOP_TAGLINE=MATCHA

# Contact (footer + contact page + order notifications)
CONTACT_EMAIL=hello@YOUR_DOMAIN.COM
NOTIFY_EMAIL=hello@YOUR_DOMAIN.COM
WHATSAPP_PHONE=85620XXXXXXXX
FACEBOOK_URL=https://www.facebook.com/YOUR_PAGE
LINE_URL=https://line.me/ti/p/YOUR_LINE_ID

# Bank transfer (checkout + payment notice)
BANK_NAME=BCEL
BANK_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
BANK_ACCOUNT_NAME=YOUR_NAME
BANK_QR_IMAGE_URL=https://example.com/bcel-qr.png

SITE_URL=https://matcha-shopbeta.onrender.com
WAKE_PAGE_URL=https://iboy5070.github.io/matcha_shopbeta/

# Google OAuth (optional — customer Gmail login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — required for real email alerts (otherwise dummy backend, no mail sent)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=hello@YOUR_DOMAIN.COM

# Optional analytics / LINE Notify
GA_MEASUREMENT_ID=
LINE_NOTIFY_TOKEN=

# First deploy only: create admin via shell
# python manage.py createsuperuser
