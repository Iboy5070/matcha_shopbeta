# ============================================================
# .env — production (copy ໄປ /home/deploy/matcha_shopbeta/.env)
# ============================================================

# ສຸ່ມດ້ວຍ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_KEY

DEBUG=False
ALLOWED_HOSTS=YOUR_DOMAIN.COM,www.YOUR_DOMAIN.COM

# PostgreSQL ໃນ VPS
DATABASE_URL=postgres://matcha:CHANGE_THIS_PASSWORD@localhost:5432/matcha_shop

# ຂໍ້ມູນຕິດຕໍ່ (ສະແດງໃນ footer + ໜ້າຕິດຕໍ່)
CONTACT_EMAIL=hello@YOUR_DOMAIN.COM
WHATSAPP_PHONE=85620XXXXXXXX
# WHATSAPP_URL=https://wa.me/85620XXXXXXXX
FACEBOOK_URL=https://www.facebook.com/YOUR_PAGE
LINE_URL=https://line.me/ti/p/YOUR_LINE_ID
