SECRET_KEY=replace-this-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (run: docker compose up -d db  OR  make db)
DATABASE_URL=postgres://matcha:matcha@127.0.0.1:5432/matcha_shop
# Local without Docker: USE_SQLITE=1  (uses db.sqlite3)
# USE_SQLITE=1

# Google OAuth (Gmail login — optional)
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI: https://YOUR-DOMAIN/auth/google/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shop branding (The 196 Haus + MATCHA)
SHOP_NAME=The 196 Haus
SHOP_TAGLINE=MATCHA
# SHOP_BRAND auto = "The 196 Haus MATCHA"

# Optional contact links (shown on site footer + contact page)
CONTACT_EMAIL=hello@example.com
WHATSAPP_PHONE=8562012345678
# WHATSAPP_URL=https://wa.me/8562012345678
FACEBOOK_URL=https://www.facebook.com/yourpage
LINE_URL=https://line.me/ti/p/@yourline

# Bank transfer (shown at checkout)
BANK_NAME=BCEL
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_NAME=Suliyo Inthavong
# Screenshot LAO QR from BCEL One → upload to CDN
BANK_QR_IMAGE_URL=https://example.com/bcel-qr.png

# Supabase Storage for payment slips (optional — auto URL from DATABASE_URL if omitted)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_SLIP_BUCKET=slips

# Local dev — must match where runserver runs (fixes admin image/slip previews)
SITE_URL=http://127.0.0.1:8000
# Production example:
# SITE_URL=https://matcha-shopbeta.onrender.com
WAKE_PAGE_URL=https://iboy5070.github.io/matcha_shopbeta/
NOTIFY_EMAIL=hello@example.com
GA_MEASUREMENT_ID=
LINE_NOTIFY_TOKEN=

# Optional SMTP (Gmail app password, SendGrid, etc.)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
